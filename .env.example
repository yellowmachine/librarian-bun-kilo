# ─── Base de datos ────────────────────────────────────────────────────────────
# URL para la app (rol limitado: solo SELECT/INSERT/UPDATE/DELETE)
DATABASE_URL="postgres://scholarly_app:password@localhost:5433/scholarly"

# URL para migraciones (rol con privilegios: CREATE SCHEMA, ALTER TABLE, etc.)
# Si no se define, se usa DATABASE_URL como fallback.
MIGRATION_DATABASE_URL="postgres://scholarly:password@localhost:5433/scholarly"

# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública de la app, sin trailing slash.
# Desarrollo: http://localhost:5173
# Producción: https://tudominio.com
ORIGIN="http://localhost:5173"

# Puerto del servidor Node (adapter-node). Por defecto 3000.
PORT=3000

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
# IMPORTANTE: debe ser el mismo valor en Librarian y Scholio (comparten sesiones)
BETTER_AUTH_SECRET=""

# Orígenes de confianza: lista separada por comas de las URLs de todas las apps del ecosistema.
# Desarrollo:   TRUSTED_ORIGINS="http://localhost:5173,http://localhost:5174"
# Producción:   TRUSTED_ORIGINS="https://scholio.review,https://librarian.scholio.review"
TRUSTED_ORIGINS="http://localhost:5173,http://localhost:5174"

# Dominio de la cookie para SSO entre subdominios.
# Desarrollo:  dejar vacío (la cookie solo aplica a localhost)
# Producción:  COOKIE_DOMAIN=".scholio.review"
COOKIE_DOMAIN=""

# GitHub OAuth (opcional — eliminar de auth.ts si no se usa)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
# Necesario para verificación de email al registrarse
RESEND_API_KEY=""
EMAIL_FROM="Librarian <noreply@librarian.scholio.review>"

# ─── Sentry (opcional) ────────────────────────────────────────────────────────
SENTRY_DSN=""
PUBLIC_SENTRY_DSN=""
